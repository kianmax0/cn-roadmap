---
import DocsLayout from '../../layouts/DocsLayout.astro';
import { getCollection, render } from 'astro:content';
import { NAV, UI, type Locale } from '../../lib/nav';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  const paths = [];

  for (const locale of ['zh', 'en'] as Locale[]) {
    for (const item of NAV) {
      if (item.slug === 'home') continue;
      const id = `${locale}/${item.slug}`;
      const entry = docs.find((d) => d.id === id);
      if (!entry) continue;
      paths.push({
        params: { lang: locale, slug: item.slug },
        props: { entry, locale, slug: item.slug },
      });
    }
  }

  return paths;
}

const { entry, locale, slug } = Astro.props;
const { Content, headings } = await render(entry);
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<DocsLayout
  locale={locale}
  title={entry.data.title}
  description={entry.data.description}
  slug={slug}
>
  <h1>{entry.data.title}</h1>
  <p class="page-meta">
    {UI.version} · {UI.verified[locale]}
  </p>
  {
    tocHeadings.length > 1 && (
      <nav class="toc" aria-label={UI.toc[locale]}>
        <p class="toc__title">{UI.toc[locale]}</p>
        <ul>
          {tocHeadings.map((h) => (
            <li style={h.depth === 3 ? 'margin-left:0.85rem' : undefined}>
              <a href={`#${h.slug}`}>{h.text}</a>
            </li>
          ))}
        </ul>
      </nav>
    )
  }
  <article class="content" data-enhance>
    <Content />
  </article>
</DocsLayout>

<script>
  function enhanceContent() {
    const root = document.querySelector('[data-enhance]');
    if (!root) return;

    root.querySelectorAll('table').forEach((table) => {
      if (table.parentElement?.classList.contains('table-wrap')) return;
      const wrap = document.createElement('div');
      wrap.className = 'table-wrap';
      table.parentNode?.insertBefore(wrap, table);
      wrap.appendChild(table);
    });

    const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT);
    const nodes: Text[] = [];
    let node: Node | null;
    while ((node = walker.nextNode())) {
      if (node.nodeValue && /\[[^\]]+\]/.test(node.nodeValue)) {
        nodes.push(node as Text);
      }
    }

    const known = new Set([
      '核心',
      '推荐',
      '选修',
      '开放',
      '平台制',
      '图书',
      '参考',
      '进阶',
      '主教材',
      '进阶参考',
      '开放阅读',
      '开放在线阅读',
      '开放材料',
      '工具教程',
      '专题课程',
      '补充',
      '经典',
      '工具',
      '图书/作者开放版',
      'core',
      'recommended',
      'elective',
      'open',
      'platform',
      'book',
      'reference',
      'advanced',
      'primary text',
      'open access',
      'open online',
      'open materials',
      'tool tutorial',
      'course',
      'supplement',
      'classic',
      'tool',
      'book / author OA',
    ]);

    for (const textNode of nodes) {
      const text = textNode.nodeValue || '';
      const frag = document.createDocumentFragment();
      const parts = text.split(/(\[[^\]]+\])/g);
      for (const part of parts) {
        const m = part.match(/^\[([^\]]+)\]$/);
        if (m && known.has(m[1])) {
          const span = document.createElement('span');
          span.className = 'tag';
          span.textContent = m[1];
          frag.appendChild(span);
        } else {
          frag.appendChild(document.createTextNode(part));
        }
      }
      textNode.parentNode?.replaceChild(frag, textNode);
    }
  }

  enhanceContent();
</script>

<script>
  async function renderMermaid() {
    const targets: HTMLElement[] = [];

    document.querySelectorAll('pre').forEach((pre) => {
      const code = pre.querySelector('code');
      const cls = `${pre.className} ${code?.className || ''}`;
      if (!/language-mermaid|mermaid/.test(cls)) return;
      const source = (code?.textContent || pre.textContent || '').trim();
      if (!source) return;
      const div = document.createElement('div');
      div.className = 'mermaid';
      div.textContent = source;
      pre.replaceWith(div);
      targets.push(div);
    });

    if (!targets.length) return;

    const mermaid = (await import('mermaid')).default;
    const theme =
      document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'neutral';
    mermaid.initialize({
      startOnLoad: false,
      theme,
      securityLevel: 'loose',
      fontFamily: 'Source Sans 3, sans-serif',
    });
    await mermaid.run({ nodes: targets });
  }

  renderMermaid();
  window.addEventListener('theme-change', () => {
    if (document.querySelector('.mermaid')) location.reload();
  });
</script>
